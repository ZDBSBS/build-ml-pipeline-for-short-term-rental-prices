name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: Name of the input dataset artifact to clean
        type: string

      output_artifact:
        description: Name of the output cleaned dataset artifact
        type: string

      output_type:
        description: Type of the output artifact (e.g. cleaned_data)N
        type: string

      output_description:
        description: Description of the output artifact
        type: string

      min_price:
        description: Minimum allowed price (EDA-based)
        type: string

      max_price:
        description: Maximum allowed price (EDA-based)
        type: string


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price} 
